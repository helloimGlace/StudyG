<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <display-name>StudyGameWeb</display-name>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.studg.controller.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>com.studg.controller.MainController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.studg.controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>SubjectServlet</servlet-name>
        <servlet-class>com.studg.controller.SubjectController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubjectServlet</servlet-name>
        <url-pattern>/subjects</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LearnServlet</servlet-name>
        <servlet-class>com.studg.controller.LearnController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LearnServlet</servlet-name>
        <url-pattern>/learn</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>TestServlet</servlet-name>
        <servlet-class>com.studg.controller.TestController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestServlet</servlet-name>
        <url-pattern>/test</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>GameServlet</servlet-name>
        <servlet-class>com.studg.controller.GameController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GameServlet</servlet-name>
        <url-pattern>/game</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>MysteryServlet</servlet-name>
        <servlet-class>com.studg.controller.MysteryController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MysteryServlet</servlet-name>
        <url-pattern>/mystery</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>OpenBoxServlet</servlet-name>
        <servlet-class>com.studg.controller.OpenBoxController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OpenBoxServlet</servlet-name>
        <url-pattern>/openbox</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.studg.controller.RegisterController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ClearPickedServlet</servlet-name>
        <servlet-class>com.studg.controller.ClearPickedController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClearPickedServlet</servlet-name>
        <url-pattern>/clearpicked</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ShopServlet</servlet-name>
        <servlet-class>com.studg.controller.ShopController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ShopServlet</servlet-name>
        <url-pattern>/shop</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ShopAdminController</servlet-name>
        <servlet-class>com.studg.controller.ShopAdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ShopAdminController</servlet-name>
        <url-pattern>/admin/shop</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/MainController</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>
</web-app>
